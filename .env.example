# Copy to .env and fill in. .env is gitignored. Use THROWAWAY testnet keys only.
# Load into your shell with:  set -a; source .env; set +a

# ---- Avalanche Fuji ----
RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
CHAIN_ID=43113

# ---- Wallets (throwaway testnet keys only — these end up in local config) ----
# Treasury omnibus wallet: holds USDC, signs payments + ERC-8004 feedback.
# Fund with: test USDC (faucet.circle.com, Avalanche Fuji) + a little test AVAX.
TREASURY_PRIVATE_KEY=0xYOUR_TREASURY_PRIVATE_KEY

# Facilitator signer wallet: submits settlement txs and pays gas.
# Fund with: test AVAX (build.avax.network console faucet).
FACILITATOR_PRIVATE_KEY=0xYOUR_FACILITATOR_PRIVATE_KEY

# ---- Smoke test (smoke-test/) ----
PAY_TO=0xDESTINATION_ADDRESS          # any address you control (e.g. a 2nd wallet)
FACILITATOR_URL=http://localhost:8080
USDC_ADDRESS=0x5425890298aed601595a70AB815c96711a31Bc65
AMOUNT=10000                          # 0.01 USDC (6 decimals, atomic units)
NETWORK=avalanche-fuji                # if /verify rejects, try: eip155:43113
USDC_DOMAIN_NAME=USD Coin             # verified on-chain — do not guess
USDC_DOMAIN_VERSION=2                 # verified on-chain
MAX_TIMEOUT_SECONDS=300

# ---- ERC-8004 deploy (contracts/) ----
# The deploy repo reads these exact names (derived from the `avalancheFuji` network key).
AVALANCHE_FUJI_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
AVALANCHE_FUJI_PRIVATE_KEY=0xYOUR_TREASURY_PRIVATE_KEY
# Filled in after deploy:
IDENTITY_REGISTRY_ADDRESS=
REPUTATION_REGISTRY_ADDRESS=
